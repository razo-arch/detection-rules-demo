{
    "rule_id":  "custom-001",
    "name":  "Suspicious PowerShell Encoded Command",
    "description":  "Detects PowerShell execution with encoded commands, commonly used to bypass detection.",
    "severity":  "high",
    "risk_score":  73,
    "type":  "query",
    "language":  "kuery",
    "query":  "process.name: powershell.exe and process.args: *encodedcommand*",
    "index":  [
                  "winlogbeat-*",
                  "logs-endpoint.events.*"
              ],
    "tags":  [
                 "execution",
                 "T1059.001",
                 "Windows",
                 "PowerShell"
             ],
